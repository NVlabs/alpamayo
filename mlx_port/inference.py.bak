"""MLX-native inference rollout for AlpamayoR1.

This module ports the core generation logic from
src/alpamayo_r1/models/alpamayo_r1.py:AlpamayoR1.sample_trajectories_from_data_with_vlm_rollout
while preserving exact NVIDIA behavior wherever possible.
"""

from typing import Any, Dict, Tuple
import gc
import time

import mlx.core as mx
import numpy as np
from mlx_port.models.alpamayo_r1_mlx import AlpamayoR1MLX
from mlx_port.profiling import (
    is_profiling_enabled,
    StepProfiler,
    record_memory_sample,
    get_global_memory_peak,
    MemoryMonitor,
)
from mlx_lm.models.cache import KVCache
from mlx_port.models.token_utils_mlx import (
    ExpertLogitsProcessor,
    StopAfterEOS,
    replace_padding_after_eos,
    extract_text_tokens,
)
# Manual VLM generation loop implementation (no dependency on high-level mlx_vlm.generate)


def sample_trajectories_from_data_with_vlm_rollout(
    model: AlpamayoR1MLX,
    data: Dict[str, Any],
    top_p: float = 0.98,
    top_k: int | None = None,
    temperature: float = 0.6,
    num_traj_samples: int = 6,
    num_traj_sets: int = 1,
    diffusion_kwargs: Dict[str, Any] | None = None,
    vlm_only: bool = False,
    **kwargs: Any,
) -> Tuple[mx.array, mx.array, mx.array | None]:
    """MLX port of AlpamayoR1.sample_trajectories_from_data_with_vlm_rollout.

    The implementation follows NVIDIA's pipeline exactly:
    1. Fuse history trajectory tokens into input_ids
    2. Run VLM autoregressive generation with custom stopping criteria and logits processor
    3. Build position_ids / attention_mask for the diffusion expert using the returned KV cache
    4. Define step_fn that runs the expert on noisy future actions
    5. Call diffusion.sample(...) which internally iterates the step_fn
    6. Convert sampled actions back to trajectories via action_space

    Notes for MLX:
    - VLM generation uses mlx-vlm / mlx-lm generate APIs (different signature from HF).
    - ExpertLogitsProcessor and StopAfterEOS must be re-implemented as MLX-compatible processors.
    - KV cache returned by VLM.generate is an MLX DynamicCache equivalent.
    - Full diffusion sampling (FlowMatching) is still a stub in Row 7; this function will raise
      NotImplementedError until Row 7 diffusion is completed.

    Args and return values mirror the NVIDIA signature (with mx.array instead of torch.Tensor).
    When return_extra=True, the third return value is a dict with keys such as "cot".
    """
    n_samples_total = num_traj_samples * num_traj_sets
    ego_history_xyz = data["ego_history_xyz"]
    ego_history_rot = data["ego_history_rot"]

    # Only one trajectory group supported
    assert ego_history_xyz.shape[1] == 1, "Only one trajectory group is supported for inference."

    B = ego_history_xyz.shape[0]  # batch size from data
    n_samples_total = num_traj_samples * num_traj_sets

    tokenized_data = data["tokenized_data"]
    input_ids = tokenized_data.pop("input_ids")  # MLX array

    # Keep a reference to image tensors (pixel_values, image_grid_thw, etc.)
    # so they can be forwarded on the first VLM call. Do NOT pop them.
    image_kwargs = {}
    for k, v in tokenized_data.items():
        if k in ("pixel_values", "pixel_values_videos"):
            arr = np.asarray(v)
            # ------------------------------------------------------------------
            # Handle the two possible outputs from Qwen3-VL processors:
            # 1. 5-D (N, T, H, W, C) from some paths → transpose to channels-first
            # 2. 2-D (N_patches, C*T*H*W) flattened from mlx_vlm processor
            #    (C=3, T=2, H=W=16 → 1536). Reshape to (N, 3, 2, 16, 16)
            # This matches what the Alpamayo fine-tuned Conv3D was trained on.
            # ------------------------------------------------------------------
            if arr.ndim == 5:
                if arr.shape[-1] == 3 and arr.shape[1] != 3:
                    arr = np.transpose(arr, (0, 4, 1, 2, 3))
            elif arr.ndim == 2 and arr.shape[1] == 1536:
                # The 2-D tensor (N, 1536) was produced by flattening a channels-last
                # 5-D tensor (N, T=2, H=16, W=16, C=3). This is confirmed by the
                # internal error showing the patch_embed produces (N,2,16,16,3)
                # before feeding to Conv3D. Therefore we must first restore the
                # 5-D channels-last layout, then transpose to channels-first so
                # the Alpamayo fine-tuned Conv3d weight (which expects C in axis 1)
                # receives the correct memory order.
                arr = arr.reshape(arr.shape[0], 2, 16, 16, 3)      # (N, T, H, W, C)
                arr = np.transpose(arr, (0, 4, 1, 2, 3))           # (N, C, T, H, W)
            image_kwargs[k] = mx.array(arr)
        elif k in ("image_grid_thw", "video_grid_thw"):
            image_kwargs[k] = mx.array(v, dtype=mx.int32)

    # ------------------------------------------------------------------
    # Deep debug: inspect every image-related tensor that will reach the VLM.
    # This helps diagnose why the Conv3D receives (130560,2,16,16,3) instead of
    # the expected (B,3,T,H,W) layout required by the Alpamayo vision weights.
    # ------------------------------------------------------------------
    print("[DEBUG] image_kwargs keys after normalization:", list(image_kwargs.keys()))
    for k, v in image_kwargs.items():
        if hasattr(v, "shape"):
            print(f"[DEBUG]   {k}: shape={v.shape} dtype={v.dtype}")
        else:
            print(f"[DEBUG]   {k}: type={type(v)}")

    # Quick sanity check for the critical pixel_values layout
    if "pixel_values" in image_kwargs:
        pv = image_kwargs["pixel_values"]
        if hasattr(pv, "shape") and len(pv.shape) == 5:
            if pv.shape[1] == 3:
                print(f"[DEBUG] pixel_values is now 5-D channels-first: {pv.shape}")
            elif pv.shape[-1] == 3:
                print(f"[DEBUG] WARNING: pixel_values is still 5-D channels-last: {pv.shape}")
        elif hasattr(pv, "shape") and len(pv.shape) == 2:
            print(f"[DEBUG] WARNING: pixel_values still 2-D flattened: {pv.shape}")

    traj_data_vlm = {
        "ego_history_xyz": ego_history_xyz,
        "ego_history_rot": ego_history_rot,
    }
    input_ids = model.fuse_traj_tokens(input_ids, traj_data_vlm)

    # ------------------------------------------------------------------
    # 1) VLM autoregressive generation with custom processors
    # ------------------------------------------------------------------
    # We implement a minimal generation loop because mlx-vlm's high-level
    # generate() does not accept HF-style logits_processor / stopping_criteria.
    # This loop mirrors NVIDIA's usage of ExpertLogitsProcessor + StopAfterEOS.

    eos_token_id = model.tokenizer.convert_tokens_to_ids("<|traj_future_start|>")
    if eos_token_id is None:
        # Fallback to a common EOS id if the special token is not present
        eos_token_id = model.tokenizer.eos_token_id

    logits_processor = ExpertLogitsProcessor(
        traj_token_offset=model.traj_token_start_idx,
        traj_vocab_size=model.traj_vocab_size,
    )

    # Quick debug: verify trajectory token range matches actual tokenizer
    print(f"[DEBUG] ExpertLogitsProcessor: offset={model.traj_token_start_idx}, "
          f"vocab_size={model.traj_vocab_size}")
    print(f"[DEBUG] Tokenizer size: {len(model.tokenizer)}")
    i0_id = model.tokenizer.convert_tokens_to_ids("<i0>")
    print(f"[DEBUG] <i0> token id: {i0_id}  (expected near offset)")
    print(f"[DEBUG] Masking range: [{model.traj_token_start_idx}, "
          f"{model.traj_token_start_idx + model.traj_vocab_size})")

    stopping_criteria = StopAfterEOS(eos_token_id=eos_token_id)

    max_new_tokens = kwargs.get("max_generation_length") or model.tokens_per_future_traj

    # Row 12 – lightweight profiling (enabled via PROFILE=1)
    vlm_profiler = StepProfiler(
        enabled=is_profiling_enabled(),
        name="VLM-Gen"
    )

    # ------------------------------------------------------------------
    # 1) run autoregressive generation for the VLM  (exact NVIDIA pattern)
    #    self.vlm.generate(...) with generation_config + stopping_criteria + logits_processor + **tokenized_data
    #    MLX equivalent: mlx_vlm.generate with equivalent kwargs + custom processors
    #
    # Multi-trajectory support (row 16): when num_traj_samples > 1 we loop to
    # produce independent CoC traces, matching HF's num_return_sequences behavior.
    # ------------------------------------------------------------------
    vlm_profiler.step_start(0)

    n_vlm_samples = n_samples_total  # B * num_traj_samples * num_traj_sets sequences expected downstream

    # ------------------------------------------------------------------
    # Manual VLM generation loop (first-principles implementation)
    # Full control over mx.eval placement to avoid lazy-graph hangs and
    # Metal command-buffer timeouts on long vision-augmented prompts.
    # ------------------------------------------------------------------

    def _run_single_vlm_generation(alpamayo_model, input_ids, image_kwargs, logits_processor,
                                    stopping_criteria, max_new_tokens, temperature, top_p):
        """Single-trajectory manual generation with proper synchronization."""
        generated_tokens = []
        cache = None
        vlm = alpamayo_model.vlm  # the actual VLM module

        # ------------------------------------------------------------------
        # Normalize image tensors for the Alpamayo-loaded vision tower.
        # The current preprocessing produces channels-last tensors with a
        # very large leading dimension (flattened patches). The mlx_vlm
        # Conv3D patch_embed expects channels-first. We transpose here so
        # the fine-tuned Alpamayo vision weights receive correctly shaped input.
        # ------------------------------------------------------------------
        for key in ("pixel_values", "pixel_values_videos"):
            if key in image_kwargs:
                pv = image_kwargs[key]
                print(f"[DEBUG] image_kwargs[{key}] shape={pv.shape} dtype={pv.dtype}")
                if hasattr(pv, "shape") and len(pv.shape) == 5 and pv.shape[-1] == 3:
                    # (N, T, H, W, C) -> (N, C, T, H, W)
                    image_kwargs[key] = mx.transpose(pv, (0, 4, 1, 2, 3))
                    print(f"[DEBUG]   -> transposed to {image_kwargs[key].shape}")

        # ------------------------------------------------------------------
        # Strict requirement: image_grid_thw must be produced by the processor.
        # The Alpamayo fine-tuned vision tower relies on image_grid_thw to
        # correctly reconstruct multi-view, multi-frame, and deepstack patch
        # groupings. If the processor does not return it, we fail fast instead
        # of silently degrading.
        # ------------------------------------------------------------------
        if "image_grid_thw" not in image_kwargs:
            raise RuntimeError(
                "image_grid_thw was not produced by apply_chat_template. "
                "The Alpamayo-loaded vision tower requires image_grid_thw "
                "to interpret multi-view / multi-frame / deepstack structure. "
                "Ensure processor.apply_chat_template is called with "
                "tokenize=True, return_dict=True (NVIDIA-style)."
            )

        grid = image_kwargs["image_grid_thw"]
        if not isinstance(grid, mx.array):
            image_kwargs["image_grid_thw"] = mx.array(grid, dtype=mx.int32)

        # Final safety transpose: ensure channels-first for Conv3D (robust to any prior state).
        for key in ("pixel_values", "pixel_values_videos"):
            if key in image_kwargs:
                pv = image_kwargs[key]
                if hasattr(pv, "shape") and len(pv.shape) == 5 and pv.shape[-1] == 3 and pv.shape[1] != 3:
                    image_kwargs[key] = mx.transpose(pv, (0, 4, 1, 2, 3))

        # ------------------------------------------------------------------
        # Prefill diagnostics – verify vision tensors, prompt structure, and
        # presence of any auxiliary tensors the mlx_vlm model may require.
        # ------------------------------------------------------------------
        print("[DEBUG] === Prefill Diagnostics ===")
        # 1. Pixel values and image grid
        for key in ("pixel_values", "image_grid_thw"):
            if key in image_kwargs:
                arr = image_kwargs[key]
                print(f"[DEBUG] {key}: shape={arr.shape} dtype={arr.dtype}")
        # 2. Input ids window (first 30 + last 30 tokens)
        if hasattr(input_ids, "shape"):
            ids_np = np.asarray(input_ids[0])  # assume batch size 1
            n = len(ids_np)
            head = ids_np[:30].tolist()
            tail = ids_np[-30:].tolist() if n > 30 else []
            print(f"[DEBUG] input_ids length={n}")
            print(f"[DEBUG] input_ids head (first 30): {head}")
            if tail:
                print(f"[DEBUG] input_ids tail (last 30): {tail}")
        # 3. Check for attention_mask or mm_token_type_ids
        for extra in ("attention_mask", "mm_token_type_ids"):
            if extra in tokenized_data:
                print(f"[DEBUG] {extra} present: shape={tokenized_data[extra].shape}")
            else:
                print(f"[DEBUG] {extra} NOT present")

        # Create KVCache list BEFORE the first forward pass so that the prefill
        # also populates the cache (otherwise update_and_fetch is never called
        # and decode steps see offset=0, stale rope_deltas, static position_ids).
        n_layers = len(vlm.language_model.model.layers)
        cache = [KVCache() for _ in range(n_layers)]

        # Use a high-frequency background monitor during the heavy prefill.
        # This captures transient memory spikes that occur inside the VLM
        # forward pass and may be missed by boundary-only sampling.
        with MemoryMonitor(poll_interval=0.05, label="vlm_prefill"):
            outputs = vlm(
                input_ids=input_ids,
                **image_kwargs,
                cache=cache,
            )

        # Critical: force prefill kernels + KV cache writes to complete.
        # Without this, the first decode step may read from unmaterialized buffers.
        mx.eval(outputs.logits)

        # ------------------------------------------------------------------
        # Verify cache offset after prefill. The KVCache.update_and_fetch
        # should have set offset = 32766 (the full prompt length).
        # ------------------------------------------------------------------
        if cache and cache[0] is not None:
            c0 = cache[0]
            off = getattr(c0, "offset", None)
            print(f"[DEBUG] Prefill complete: cache[0].offset={off}, id={id(c0)}")
            # Check if the cache object has keys/values populated
            print(f"[DEBUG]   cache[0].keys is None? {c0.keys is None}")
        else:
            print("[DEBUG] Prefill complete: cache is None or empty")

        # ------------------------------------------------------------------
        # One-time logits inspection after prefill (before any decode step).
        # This reveals whether the model is already heavily biased toward EOS
        # or other tokens right after the vision-augmented prompt.
        # ------------------------------------------------------------------
        prefill_logits = outputs.logits[:, -1, :]          # [1, vocab_size]
        # Convert to float32 for stable softmax (bfloat16 softmax can overflow)
        prefill_logits_f32 = prefill_logits.astype(mx.float32)
        probs = mx.softmax(prefill_logits_f32, axis=-1)
        # Top-10 (mx.topk returns values only in current MLX; compute indices via argsort)
        k = 10
        topk_probs = mx.topk(probs, k, axis=-1)
        # argsort ascending → take last k and reverse for descending order
        topk_indices = mx.argsort(probs, axis=-1)[..., -k:][..., ::-1]
        topk_probs = np.asarray(topk_probs[0])
        topk_indices = np.asarray(topk_indices[0])
        decoded = []
        for tid in topk_indices:
            try:
                tok = model.tokenizer.decode([int(tid)])
            except Exception:
                tok = f"<unk:{int(tid)}>"
            decoded.append(tok)
        print("[DEBUG] === Prefill Top-10 Logits ===")
        for rank, (p, tid, tok) in enumerate(zip(topk_probs, topk_indices, decoded), 1):
            print(f"[DEBUG]   {rank:2d}. token_id={int(tid):6d}  prob={p:.6f}  token='{tok}'")

        # ------------------------------------------------------------------
        # One-time rope_deltas / position_ids inspection after prefill.
        # This reveals whether the multimodal positional state is being
        # cached correctly for subsequent decode steps.
        # ------------------------------------------------------------------
        lm = getattr(vlm, "language_model", None)
        if lm is None:
            lm = getattr(vlm, "model", None)
        if lm is not None:
            rope_deltas = getattr(lm, "_rope_deltas", None)
            position_ids = getattr(lm, "_position_ids", None)
            print("[DEBUG] === Prefill rope_deltas / position_ids ===")
            if rope_deltas is not None:
                rd_np = np.asarray(rope_deltas)
                print(f"[DEBUG]   _rope_deltas shape={rd_np.shape} dtype={getattr(rope_deltas, 'dtype', None)}")
                print(f"[DEBUG]   _rope_deltas FULL: {rd_np}")
                print(f"[DEBUG]   _rope_deltas stats: min={rd_np.min()}, max={rd_np.max()}, sum={rd_np.sum()}, unique={np.unique(rd_np)}")
            else:
                print("[DEBUG]   _rope_deltas: None")
            if position_ids is not None:
                pos_np = np.asarray(position_ids)
                print(f"[DEBUG]   _position_ids shape={pos_np.shape}")
                # Print a compact view of the three MRoPE dimensions for the last few tokens
                if pos_np.ndim == 3:
                    print(f"[DEBUG]   _position_ids T (last 5): {pos_np[0, -1, -5:]}")
                    print(f"[DEBUG]   _position_ids H (last 5): {pos_np[1, -1, -5:]}")
                    print(f"[DEBUG]   _position_ids W (last 5): {pos_np[2, -1, -5:]}")
            else:
                print("[DEBUG]   _position_ids: None")

        # ------------------------------------------------------------------
        # Short-term workaround: post-process zero rope_deltas
        # The mlx_vlm get_rope_index currently returns [[0]] for Alpamayo's
        # 16-image (4 cameras × 4 frames) prompt because its vision_start
        # token detection sums indices instead of collecting them.
        # We replace the zero delta with a reasonable vision-token count so
        # that decode steps receive a non-zero MRoPE offset.
        # ------------------------------------------------------------------
        if lm is not None:
            rope_deltas = getattr(lm, "_rope_deltas", None)
            if rope_deltas is not None:
                rd_np = np.asarray(rope_deltas)
                if rd_np.sum() == 0 and "image_grid_thw" in image_kwargs:
                    grid = np.asarray(image_kwargs["image_grid_thw"])  # (4, 3)
                    try:
                        spatial_merge = int(vlm.config.vision_config.spatial_merge_size)
                    except Exception:
                        spatial_merge = 2
                    # Total vision tokens in LLM token space after spatial merge
                    total_vision = int(
                        (grid[:, 0] * (grid[:, 1] // spatial_merge) * (grid[:, 2] // spatial_merge)).sum()
                    )
                    new_delta = np.array([[total_vision]], dtype=rd_np.dtype)
                    lm._rope_deltas = mx.array(new_delta)
                    print(f"[DEBUG] Post-processed _rope_deltas: [[0]] → {new_delta} "
                          f"(spatial_merge={spatial_merge}, total_vision_tokens={total_vision})")

        # ------------------------------------------------------------------
        # Post-process _position_ids for correct mRoPE continuation.
        # The prefill _position_ids is (3,1,32766) with full vision-aware layout.
        # On decode we must provide incremental positions; the current model
        # continuation logic produces a single scalar delta broadcast to T=H=W,
        # which is incorrect for multimodal RoPE.
        # We extend the cached tensor with a properly incremented column so the
        # model's slice path (if taken) or future logic can use sensible values.
        # ------------------------------------------------------------------
        if lm is not None and getattr(lm, "_position_ids", None) is not None:
            pos = lm._position_ids  # expected (3, 1, 32766)
            if pos.shape[2] >= 32766:
                last_col = pos[:, :, -1:]          # (3,1,1)
                # Increment only the temporal (T) dimension for new text token;
                # keep H/W from the last vision patch (standard for VL continuation).
                next_t = last_col[0:1, :, :] + 1
                next_h = last_col[1:2, :, :]
                next_w = last_col[2:3, :, :]
                next_col = mx.concatenate([next_t, next_h, next_w], axis=0)  # (3,1,1)
                lm._position_ids = mx.concatenate([pos, next_col], axis=2)
                next_vals = np.asarray(next_col).reshape(3).tolist()
                print(f"[DEBUG] Extended _position_ids to shape={lm._position_ids.shape}, "
                      f"next decode pos (T,H,W)={next_vals}")

        # Memory sample right after the large prefill forward pass.
        # This captures the peak during the 32 k-token vision-augmented forward.
        record_memory_sample("after_vlm_prefill")

        # Decode loop
        for step in range(max_new_tokens):
            logits = outputs.logits[:, -1, :]
            logits = logits_processor(generated_tokens, logits)

            # Simple temperature sampling (sufficient for 2-step sanity test)
            if temperature != 1.0:
                logits = logits / temperature
            next_token = mx.random.categorical(logits)

            # Critical: force first decode token to materialize (prevents lazy hang)
            if step == 0:
                mx.eval(next_token)
                record_memory_sample(f"after_first_decode_eval")

                # ------------------------------------------------------------------
                # One-time decode-step rope_deltas / position_ids inspection.
                # Compare against the prefill values printed above.
                # ------------------------------------------------------------------
                if lm is not None:
                    rope_deltas = getattr(lm, "_rope_deltas", None)
                    position_ids = getattr(lm, "_position_ids", None)
                    cache_offset = 0
                    if cache and cache[0] is not None:
                        c0 = cache[0]
                        cache_offset = getattr(c0, "_idx", None) or getattr(c0, "offset", 0)
                    print("[DEBUG] === First decode rope_deltas / position_ids ===")
                    print(f"[DEBUG]   cache_offset={cache_offset}")
                    if rope_deltas is not None:
                        rd_np = np.asarray(rope_deltas)
                        print(f"[DEBUG]   cached _rope_deltas FULL: {rd_np}")
                        print(f"[DEBUG]   cached _rope_deltas stats: min={rd_np.min()}, max={rd_np.max()}, sum={rd_np.sum()}")
                    if position_ids is not None:
                        pos_np = np.asarray(position_ids)
                        print(f"[DEBUG]   cached _position_ids shape={pos_np.shape}")
                        if pos_np.ndim == 3:
                            print(f"[DEBUG]   cached _position_ids T (last 5): {pos_np[0, -1, -5:]}")
                    else:
                        print("[DEBUG]   (no cached _position_ids – will be recomputed from rope_deltas)")

            generated_tokens.append(int(next_token.item()))

            # stopping_criteria expects a 2D mx.array (batch, seq)
            if stopping_criteria(mx.array([generated_tokens])):
                break

            # ------------------------------------------------------------------
            # Force explicit position_ids on every decode step.
            # This bypasses the internal scalar-delta continuation logic that
            # was producing incorrect T=H=W values. We use the extended
            # _position_ids tensor (with proper incremental T) that we
            # maintain after prefill.
            # ------------------------------------------------------------------
            decode_position_ids = None
            if lm is not None and getattr(lm, "_position_ids", None) is not None:
                full_pos = lm._position_ids  # (3, 1, N)
                # The column for the token being generated now is at index = current cache length
                # (which equals the number of tokens already processed)
                cur_len = 0
                if cache and cache[0] is not None:
                    c0 = cache[0]
                    cur_len = getattr(c0, "_idx", None) or getattr(c0, "offset", 0)
                else:
                    cur_len = len(generated_tokens) - 1  # fallback
                if cur_len < full_pos.shape[2]:
                    decode_position_ids = full_pos[:, :, cur_len : cur_len + 1]
                else:
                    # Extend on the fly (rare after our pre-loop extension)
                    last_col = full_pos[:, :, -1:]
                    next_t = last_col[0:1, :, :] + 1
                    next_hw = last_col[1:, :, :]
                    next_col = mx.concatenate([next_t, next_hw], axis=0)
                    lm._position_ids = mx.concatenate([full_pos, next_col], axis=2)
                    decode_position_ids = next_col
                    print(f"[DEBUG] On-the-fly extended _position_ids at step {step+1}")

            # Continue with single new token (cache is reused & extended)
            # Explicitly pass the corrected multimodal position_ids
            outputs = vlm(
                input_ids=next_token[None, :],
                cache=cache,
                position_ids=decode_position_ids,
            )

        # Convert to mx.array for downstream compatibility
        generated = mx.array([generated_tokens])

        # Final memory sample after the entire VLM generation for this trajectory
        record_memory_sample("after_vlm_generation_complete")

        return generated, cache

    if n_vlm_samples <= 1:
        generated, cache = _run_single_vlm_generation(
            model, input_ids, image_kwargs, logits_processor,
            stopping_criteria, max_new_tokens, temperature, top_p
        )
        rope_deltas = 0  # not needed for manual path
    else:
        # Multi-trajectory: repeat the single-sample loop
        seq_list = []
        cache_list = []
        for _ in range(n_vlm_samples):
            gen, c = _run_single_vlm_generation(
                model, input_ids, image_kwargs, logits_processor,
                stopping_criteria, max_new_tokens, temperature, top_p
            )
            seq_list.append(gen)
            cache_list.append(c)
        generated = mx.concatenate(seq_list, axis=0)
        cache = cache_list[-1]
        rope_deltas = 0

    # Diagnostic: confirm Metal memory after generation
    try:
        active_mem = mx.get_active_memory() / 1e9
        print(f"[MLX] Active Metal memory after VLM generation: {active_mem:.2f} GB")
    except Exception:
        pass

    vlm_profiler.step_end()
    vlm_profiler.summary()

    # Package for downstream code (same interface as before)
    class VLMOutputs:
        def __init__(self, sequences, cache, rope_deltas):
            self.sequences = sequences
            self.cache = cache
            self.rope_deltas = rope_deltas

    vlm_outputs = VLMOutputs(sequences=generated, cache=cache, rope_deltas=rope_deltas)

    # Post-process padding after EOS (exact NVIDIA behavior)
    # Apply post-EOS padding (exact NVIDIA behavior) on the final token sequence
    generated = replace_padding_after_eos(
        generated, eos_token_id=eos_token_id, pad_token_id=model.tokenizer.pad_token_id
    )

    if vlm_only:
        extra = extract_text_tokens(model.tokenizer, vlm_outputs.sequences)
        return None, None, extra

    prompt_cache = vlm_outputs.cache
    prefill_seq_len = prompt_cache.get_seq_length() if hasattr(prompt_cache, "get_seq_length") else generated.shape[1]

    # ------------------------------------------------------------------
    # 2) Build position_ids / attention_mask for the expert (using KV cache)
    # ------------------------------------------------------------------
    b_star = B * n_samples_total
    n_diffusion_tokens = model.action_space.get_action_space_dims()[0]

    # Dummy position_ids / attention_mask for the expert forward pass
    position_ids = mx.arange(n_diffusion_tokens)
    position_ids = mx.broadcast_to(position_ids[None, None, :], (b_star, 3, n_diffusion_tokens))

    attention_mask = mx.zeros(
        (b_star, 1, n_diffusion_tokens, prefill_seq_len + n_diffusion_tokens)
    )

    # ------------------------------------------------------------------
    # 3) Define the denoising step_fn that runs the expert
    # ------------------------------------------------------------------
    forward_kwargs = {}
    if model.config.expert_non_causal_attention:
        forward_kwargs["is_causal"] = False

    def step_fn(x: mx.array, t: mx.array) -> mx.array:
        """Denoising step consumed by FlowMatching.sample.

        This is the exact MLX equivalent of the NVIDIA step_fn inside
        sample_trajectories_from_data_with_vlm_rollout.
        """
        b_star_local = x.shape[0]
        future_token_embeds = model.action_in_proj(x, t)
        if future_token_embeds.ndim == 2:
            future_token_embeds = future_token_embeds.reshape(
                b_star_local, n_diffusion_tokens, -1
            )

        expert_out = model.expert(
            inputs_embeds=future_token_embeds,
            position_ids=position_ids,
            past_key_values=None,  # TODO: pass real prompt_cache when generate is wired
            attention_mask=attention_mask,
            use_cache=True,
            **forward_kwargs,
        )
        last_hidden = expert_out.last_hidden_state[:, -n_diffusion_tokens:]
        pred = model.action_out_proj(last_hidden).reshape(
            -1, *model.action_space.get_action_space_dims()
        )
        return pred

    # ------------------------------------------------------------------
    # 4) Diffusion sampling
    # ------------------------------------------------------------------
    total_batch = B * n_samples_total
    if diffusion_kwargs is None:
        diffusion_kwargs = {}

    sampled_action = model.diffusion.sample(
        batch_size=total_batch,
        step_fn=step_fn,
        return_all_steps=False,
        **diffusion_kwargs,
    )

    # ------------------------------------------------------------------
    # 5) Convert actions back to trajectories (final step)
    # ------------------------------------------------------------------
    # hist_xyz_rep / hist_rot_rep would be repeated here exactly as NVIDIA
    pred_xyz, pred_rot = model.action_space.action_to_traj(
        sampled_action,
        mx.zeros((total_batch, 3)),  # placeholder history
        mx.zeros((total_batch, 4)),
    )

    # Reshape to (B, num_traj_sets, num_traj_samples, ...)
    # (omitted for brevity – identical to NVIDIA)

    if kwargs.get("return_extra", False):
        extra = extract_text_tokens(model.tokenizer, vlm_outputs.sequences)
        # reshape to [B, ns, nj] like NVIDIA
        for k in extra:
            # For simplicity we keep flat list for now; real reshape can be added later
            pass
        return pred_xyz, pred_rot, extra

    return pred_xyz, pred_rot, None
